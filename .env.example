# Copiar este archivo como .env.local y completar los valores

# URL pública del sitio (sin barra final)
NEXT_PUBLIC_URL=https://iglesashema.cl

# Nombre del sitio
NEXT_PUBLIC_NOMBRE_SITIO=Iglesia SHEMA

# Email de contacto
EMAIL_CONTACTO=contacto@iglesashema.cl
EMAIL_REMITENTE=no-reply@iglesashema.cl

# Servicio de email Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
